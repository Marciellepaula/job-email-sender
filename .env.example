# =============================================
# Application
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# Database (PostgreSQL)
# =============================================
DATABASE_URL=postgres://postgres:postgres@localhost:5434/job_email_sender
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=job_email_sender

# =============================================
# JWT Authentication
# =============================================
JWT_SECRET=your-secret-key-change-in-production

# =============================================
# Admin Seed User
# =============================================
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin

# =============================================
# SMTP (provider #1 - Gmail, Outlook, etc.)
# =============================================
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# =============================================
# Mailgun (provider #2 - optional)
# https://www.mailgun.com
# =============================================
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=Your Name <mail@yourdomain.com>

# =============================================
# Resend (provider #3 - optional)
# https://resend.com
# =============================================
RESEND_API_KEY=
RESEND_FROM=Your Name <onboarding@resend.dev>

# =============================================
# Brevo (provider #4 - optional, 300 emails/day free)
# https://www.brevo.com
# =============================================
BREVO_USER=
BREVO_PASS=
BREVO_FROM=Your Name <your-brevo-login@smtp-brevo.com>

# =============================================
# Sender
# =============================================
SENDER_NAME=Marcielle Paula

# Delay between emails in ms
EMAIL_DELAY_MS=7000
