{
  "name": "job-email-sender",
  "version": "2.0.0",
  "description": "Professional REST API for automated job application emails",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "npx sequelize-cli db:migrate --env production",
    "migrate:dev": "npx sequelize-cli db:migrate --env development",
    "migrate:undo": "npx sequelize-cli db:migrate:undo --env production",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all --env production",
    "migrate:status": "npx sequelize-cli db:migrate:status --env production",
    "seed": "npx sequelize-cli db:seed:all --env production",
    "seed:undo": "npx sequelize-cli db:seed:undo:all --env production",
    "db:reset": "npx sequelize-cli db:migrate:undo:all --env production && npx sequelize-cli db:migrate --env production && npx sequelize-cli db:seed:all --env production",
    "build:frontend": "cd ../frontend && npm ci && npm run build",
    "production": "node src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.5",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mailgun.js": "^12.7.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "resend": "^6.9.3",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  }
}
