# =============================================
# Copie este arquivo como .env e preencha os valores
# cp .env.production.example .env
# =============================================

# ── Banco de Dados ───────────────────────────
POSTGRES_USER=jobsender
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_AQUI
POSTGRES_DB=job_email_sender

# ── Seguranca ────────────────────────────────
JWT_SECRET=TROCAR_POR_STRING_ALEATORIA_LONGA

# ── Admin ────────────────────────────────────
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=TROCAR_SENHA_ADMIN
ADMIN_NAME=Admin

# ── Brevo (300 emails/dia gratis) ────────────
BREVO_USER=seu_login@smtp-brevo.com
BREVO_PASS=xsmtpsib-sua-chave-aqui
BREVO_FROM=Seu Nome <seuemail@gmail.com>

# ── Resend (100 emails/dia gratis) ───────────
RESEND_API_KEY=re_sua_chave_aqui
RESEND_FROM=Seu Nome <onboarding@resend.dev>

# ── Configuracoes ────────────────────────────
SENDER_NAME=Seu Nome
EMAIL_DELAY_MS=7000
PORT=3001
